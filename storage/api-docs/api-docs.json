            "post": {
                "tags": [
                    "Authentication"
                ],
                "summary": "İstifadəçi qeydiyyatı",
                "operationId": "08136088c4862c313b35d6518bab8d3a",
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "required": [
                                    "name",
                                    "email",
                                    "password",
                                    "password_confirmation"
                                ],
                                "properties": {
                                    "name": {
                                        "type": "string",
                                        "example": "Islam"
                                    },
                                    "email": {
                                        "type": "string",
                                        "example": "user@mail.com"
                                    },
                                    "password": {
                                        "type": "string",
                                        "example": "12345678"
                                    },
                                    "password_confirmation": {
                                        "type": "string",
                                        "example": "12345678"
                                    }
                                },
                                "type": "object"
                            }
                        }
                    }
                },
                "responses": {
                    "201": {
                        "description": "Uğurlu qeydiyyat"
                    },
                    "422": {
                        "description": "Validation xətası"
                    }
                }
            }
        },
