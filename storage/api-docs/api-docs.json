        "/cars": {
            "get": {
                "tags": [
                    "Cars"
                ],
                "summary": "Bütün maşınları gətir (Filtr və Search ilə)",
                "operationId": "443cb17c5b7a91b32f5afb1e69ab15ac",
                "parameters": [
                    {
                        "name": "brand_id",
                        "in": "query",
                        "schema": {
                            "type": "integer"
                        }
                    },
                    {
                        "name": "status",
                        "in": "query",
                        "schema": {
                            "type": "string",
                            "enum": [
                                "available",
                                "sold",
                                "reserved"
                            ]
                        }
                    },
                    {
                        "name": "is_featured",
                        "in": "query",
                        "schema": {
                            "type": "boolean"
                        }
                    },
